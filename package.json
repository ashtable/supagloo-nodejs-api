{
  "name": "@supagloo/nodejs-api",
  "version": "0.0.1",
  "private": true,
  "description": "Supagloo API: Fastify service — auth/session, CRUD, OAuth, presigned URLs, job enqueueing.",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "postinstall": "check-prisma-version",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.717.0",
    "@aws-sdk/s3-request-presigner": "^3.717.0",
    "@dbos-inc/dbos-sdk": "^4.23.6",
    "@prisma/client": "7.8.0",
    "@supagloo/database-lib": "file:./supagloo-database-lib",
    "fastify": "^5.10.0",
    "fastify-type-provider-zod": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "prisma": "7.8.0",
    "tsx": "^4.23.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  }
}
