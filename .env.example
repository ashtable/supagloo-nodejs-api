# supagloo-nodejs-api ‚Äî local env for `npm run start` / `npm run dev`.
#
# Copy to `.env` (optional). In Docker Compose these are set by the `api` and
# `migrate` services; from the HOST use `localhost`, from inside the Compose
# network use host `postgres`.

# Prisma-managed application database (required ‚Äî the env loader rejects a
# missing or non-postgres value).
DATABASE_URL=postgres://supagloo:supagloo@localhost:5432/supagloo

# Server bind (optional ‚Äî these are the defaults).
PORT=4000
HOST=0.0.0.0

# --- Outbound provider base URLs (Task #9 convention) ---
# Default to the REAL provider URLs, so production needs zero config. The test
# Compose overlay (docker-compose.test.yml) overrides these to point at the
# in-network stub servers (e.g. http://github-stub:8080). GitHub needs two hosts:
# the REST API vs the user-authorization OAuth host. YOUVERSION_BASE_URL's default
# is a placeholder pending implementation-time verification.
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_OAUTH_BASE_URL=https://github.com
OPENROUTER_BASE_URL=https://openrouter.ai
GLOO_BASE_URL=https://platform.ai.gloo.com
YOUVERSION_BASE_URL=https://api.youversion.com

# --- Test-only seed gate (Task #10, ¬ß9-Q9) ---
# Optional. Gates the deterministic POST /v1/test/seed endpoint, which is only
# registered when NODE_ENV !== 'production' AND this equals '1'. Leave unset in a
# real .env (and always in prod ‚Äî the endpoint must not exist there). The e2e
# harness (docker-compose.test.yml) sets it to '1'; developers normally don't.
SUPAGLOO_ENABLE_TEST_SEED=
