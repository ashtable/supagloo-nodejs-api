# supagloo-nodejs-api — local env for `npm run start` / `npm run dev`.
#
# Copy to `.env` (optional). In Docker Compose these are set by the `api` and
# `migrate` services; from the HOST use `localhost`, from inside the Compose
# network use host `postgres`.

# Prisma-managed application database (required — the env loader rejects a
# missing or non-postgres value).
DATABASE_URL=postgres://supagloo:supagloo@localhost:5432/supagloo

# Server bind (optional — these are the defaults).
PORT=4000
HOST=0.0.0.0

# --- Outbound provider base URLs (Task #9 convention) ---
# Default to the REAL provider URLs, so production needs zero config. The test
# Compose overlay (docker-compose.test.yml) overrides these to point at the
# in-network stub servers (e.g. http://github-stub:8080). GitHub needs two hosts:
# the REST API vs the user-authorization OAuth host. YOUVERSION_BASE_URL's default
# is a placeholder pending implementation-time verification.
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_OAUTH_BASE_URL=https://github.com
OPENROUTER_BASE_URL=https://openrouter.ai
GLOO_BASE_URL=https://platform.ai.gloo.com
YOUVERSION_BASE_URL=https://api.youversion.com

# --- GitHub App (Task #11, design-delta §2.3) ---
# Required. App-level secrets/config for the GitHub App (one pair per app
# registration, shared by the API and DBOS — NOT per-user, so outside the §2.10
# encryption scheme). The API signs ~10-min App JWTs to verify installations and
# mint short-lived installation tokens, and builds the hosted install URL
# ({GITHUB_OAUTH_BASE_URL}/apps/{GITHUB_APP_SLUG}/installations/new). The private
# key is the app's PKCS#1/PKCS#8 PEM; a single-line value with escaped \n is
# accepted (normalized before signing).
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=

# --- Application secrets key (Task #12, design-delta §2.10) ---
# Required. The single AES-256-GCM key used to encrypt/decrypt per-user provider
# secrets at rest (the OpenRouter API key, the Gloo client secret). A 64-char hex
# string (32 bytes), distinct per environment. Generate one with:
#   openssl rand -hex 32
# NOT per-user data — one key per deployment, shared by the API and DBOS.
SECRETS_ENCRYPTION_KEY=

# --- Test-only seed gate (Task #10, §9-Q9) ---
# Optional. Gates the deterministic POST /v1/test/seed endpoint, which is only
# registered when NODE_ENV !== 'production' AND this equals '1'. Leave unset in a
# real .env (and always in prod — the endpoint must not exist there). The e2e
# harness (docker-compose.test.yml) sets it to '1'; developers normally don't.
SUPAGLOO_ENABLE_TEST_SEED=
